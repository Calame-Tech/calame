# Calame configuration — copy to .env and adjust.
# Every variable maps to a field in packages/cli/src/config.ts.
# Values shown are the built-in defaults; uncomment to override.

# ── Server ─────────────────────────────────────────────────────────
# CALAME_PORT=4567
# CALAME_BASE_PATH=/
# CALAME_TRUST_PROXY=false
# CALAME_CORS_ORIGINS=*

# ── Secrets / auth ─────────────────────────────────────────────────
# Admin password for the web UI (no default — must be set to enable admin login).
# CALAME_ADMIN_PASSWORD=
# Secret used to sign sessions/tokens (auto-generated to .calame-secret if unset).
# CALAME_SECRET_KEY=

# ── Storage ────────────────────────────────────────────────────────
# Directory for the SQLite database and generated files (defaults to CWD).
# CALAME_DATA_DIR=

# ── Logging ────────────────────────────────────────────────────────
# CALAME_LOG_LEVEL=info        # debug | info | warn | error
# CALAME_LOG_FORMAT=text       # text | json

# ── Database pool / query limits ───────────────────────────────────
# CALAME_DB_POOL_SIZE=10
# CALAME_DB_IDLE_TIMEOUT_MS=30000
# CALAME_QUERY_TIMEOUT_MS=10000

# ── Retention ──────────────────────────────────────────────────────
# CALAME_AUDIT_RETENTION_DAYS=90
# CALAME_CHAT_RETENTION_DAYS=30

# ── LLM (chat) ─────────────────────────────────────────────────────
# CALAME_LLM_PROVIDER=anthropic
# CALAME_LLM_ENDPOINT=          # custom/self-hosted endpoint
# CALAME_LLM_MODEL=
# CALAME_LLM_API_KEY=

# ── TLS (both required together) ───────────────────────────────────
# CALAME_TLS_CERT=
# CALAME_TLS_KEY=

# ── Rate limiting ──────────────────────────────────────────────────
# Requests per minute per MCP token. 0 = unlimited.
# CALAME_RATE_LIMIT_RPM=0

# ── Config-as-code ─────────────────────────────────────────────────
# Path to a YAML configuration file.
# CALAME_CONFIG_FILE=

# ── SMTP (email invitations) ───────────────────────────────────────
# CALAME_SMTP_HOST=
# CALAME_SMTP_PORT=587
# CALAME_SMTP_USER=
# CALAME_SMTP_PASS=
# CALAME_SMTP_FROM=

# ── OIDC / SSO (Enterprise) ────────────────────────────────────────
# CALAME_OIDC_ENABLED=false
# CALAME_OIDC_ISSUER_URL=          # e.g. https://accounts.google.com
# CALAME_OIDC_CLIENT_ID=
# CALAME_OIDC_CLIENT_SECRET=       # optional for public clients
# CALAME_OIDC_REDIRECT_URI=
# CALAME_OIDC_SCOPES=openid profile email
# CALAME_OIDC_GROUP_CLAIM=groups
# CALAME_OIDC_GROUP_MAP=           # JSON map of IdP group -> Calame profile
# CALAME_OIDC_AUTO_CREATE_USERS=true

# ── External secrets manager ───────────────────────────────────────
# CALAME_SECRETS_PROVIDER=none     # none | vault | aws
# CALAME_SECRETS_VAULT_ADDR=
# CALAME_SECRETS_VAULT_TOKEN=
# CALAME_SECRETS_AWS_REGION=

# ── LLM classifier router ──────────────────────────────────────────
# CALAME_LLM_ROUTER_ENABLED=false
# CALAME_LLM_CLASSIFIER_PROVIDER=
# CALAME_LLM_CLASSIFIER_MODEL=
# CALAME_LLM_CLASSIFIER_API_KEY=
# CALAME_LLM_CLASSIFIER_ENDPOINT=
# CALAME_LLM_ROUTER_INJECTION_THRESHOLD=0.8   # 0..1, block above this confidence

# ── RAG (Enterprise) ───────────────────────────────────────────────
CALAME_RAG_EMBED_TIMEOUT_MS=600000
CALAME_RAG_DOC_TIMEOUT_MS=300000
