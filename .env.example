# Calame — Environment Variables Reference
# Copy this file to .env and fill in the values you need.
# All variables are optional unless marked (required).

# ── Server ────────────────────────────────────────────────────────────────────

# Port to listen on (default: 4567)
CALAME_PORT=4567

# Directory where Calame stores its SQLite DB, secrets, and generated files
# Default: current working directory (dev) or /data (Docker)
CALAME_DATA_DIR=/data

# Secret key used to sign tokens. Auto-generated on first start if not set.
# Set explicitly in production to survive container restarts.
# Generate with: openssl rand -hex 32
CALAME_SECRET_KEY=

# Base path when served behind a reverse proxy at a subpath (e.g. /calame)
CALAME_BASE_PATH=/

# Set to true if Calame runs behind a reverse proxy (enables X-Forwarded-* headers)
CALAME_TRUST_PROXY=false

# Allowed CORS origins. Use * for development, restrict in production.
CALAME_CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error (default: info)
CALAME_LOG_LEVEL=info

# Log format: text | json (default: text — use json for log aggregators)
CALAME_LOG_FORMAT=text

# ── Database connections ───────────────────────────────────────────────────────

# Connection pool size for user databases (default: 10)
CALAME_DB_POOL_SIZE=10

# Idle connection timeout in milliseconds (default: 30000)
CALAME_DB_IDLE_TIMEOUT_MS=30000

# Query timeout in milliseconds (default: 10000)
CALAME_QUERY_TIMEOUT_MS=10000

# ── Data retention ────────────────────────────────────────────────────────────

# How long to keep audit logs, in days (default: 90)
CALAME_AUDIT_RETENTION_DAYS=90

# How long to keep chat history, in days (default: 30)
CALAME_CHAT_RETENTION_DAYS=30

# ── LLM — built-in chat ───────────────────────────────────────────────────────
# Only required if you use the built-in AI chat feature.

# LLM provider: anthropic | openrouter | custom (default: anthropic)
CALAME_LLM_PROVIDER=anthropic

# Model name (required if chat is used)
# Examples: claude-sonnet-4-6, gpt-4o, mistral-large-latest
CALAME_LLM_MODEL=

# API key for the LLM provider
CALAME_LLM_API_KEY=

# Custom endpoint URL (only for CALAME_LLM_PROVIDER=custom or local Ollama)
CALAME_LLM_ENDPOINT=

# ── Rate limiting ─────────────────────────────────────────────────────────────

# Max requests per minute per MCP token. 0 = unlimited (default: 0)
CALAME_RATE_LIMIT_RPM=0

# ── TLS ───────────────────────────────────────────────────────────────────────
# Optional — only needed for direct TLS termination (without a reverse proxy).

# CALAME_TLS_CERT=/path/to/cert.pem
# CALAME_TLS_KEY=/path/to/key.pem

# ── Config-as-code ────────────────────────────────────────────────────────────
# Optional — load connections and profiles from a YAML file at startup.

# CALAME_CONFIG_FILE=/path/to/calame-config.yaml

# ── SMTP — email invitations ──────────────────────────────────────────────────
# Optional — required only if you send user invitation emails.

# CALAME_SMTP_HOST=smtp.example.com
# CALAME_SMTP_PORT=587
# CALAME_SMTP_USER=user@example.com
# CALAME_SMTP_PASS=
# CALAME_SMTP_FROM=calame@example.com

# ── OIDC / SSO (enterprise) ───────────────────────────────────────────────────
# Optional — enable single sign-on via an OIDC-compatible identity provider.

# CALAME_OIDC_ENABLED=false
# CALAME_OIDC_ISSUER_URL=https://accounts.google.com
# CALAME_OIDC_CLIENT_ID=
# CALAME_OIDC_CLIENT_SECRET=
# CALAME_OIDC_REDIRECT_URI=https://calame.example.com/auth/oidc/callback
# CALAME_OIDC_SCOPES=openid profile email
# CALAME_OIDC_GROUP_CLAIM=groups
# CALAME_OIDC_GROUP_MAP={"admins":"admin","developers":"editor"}
# CALAME_OIDC_AUTO_CREATE_USERS=true

# ── Secrets manager (enterprise) ──────────────────────────────────────────────
# Optional — store database credentials in HashiCorp Vault or AWS Secrets Manager.

# CALAME_SECRETS_PROVIDER=none
#
# HashiCorp Vault:
# CALAME_SECRETS_PROVIDER=vault
# CALAME_SECRETS_VAULT_ADDR=https://vault.example.com
# CALAME_SECRETS_VAULT_TOKEN=
#
# AWS Secrets Manager:
# CALAME_SECRETS_PROVIDER=aws
# CALAME_SECRETS_AWS_REGION=eu-west-1

# ── LLM Router — prompt injection detection (enterprise) ─────────────────────
# Optional — classifies incoming chat messages to detect injection attempts.

# CALAME_LLM_ROUTER_ENABLED=false
# CALAME_LLM_CLASSIFIER_PROVIDER=anthropic
# CALAME_LLM_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# CALAME_LLM_CLASSIFIER_API_KEY=
# CALAME_LLM_CLASSIFIER_ENDPOINT=
# CALAME_LLM_ROUTER_INJECTION_THRESHOLD=0.8

# ── RAG — embedding timeouts (enterprise) ────────────────────────────────────

# Timeout for embedding requests in milliseconds (default: 600000)
# CALAME_RAG_EMBED_TIMEOUT_MS=600000

# Timeout for document processing in milliseconds (default: 300000)
# CALAME_RAG_DOC_TIMEOUT_MS=300000
