{
  "name": "calame",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "repository": "https://github.com/mgasnier95/calame",
  "author": "Calame Contributors",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"packages/*/src/**/*.tsx\" \"ee/*/src/**/*.ts\" \"ee/*/src/**/*.tsx\" \"scripts/**/*.js\"",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"ee/*/src/**/*.{ts,tsx}\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"ee/*/src/**/*.{ts,tsx}\" \"scripts/**/*.js\"",
    "test": "pnpm -r run test",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b --noEmit",
    "dev": "pnpm --filter calame run dev",
    "start": "pnpm build && pnpm dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.0",
    "typescript": "~5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@0.x": "^0.1.13",
      "path-to-regexp@8.x": "^8.4.0",
      "hono": ">=4.12.25",
      "@hono/node-server": "^1.19.13",
      "fast-uri": ">=3.1.2",
      "tar": ">=7.5.8",
      "ws": ">=8.21.0",
      "form-data": ">=4.0.6",
      "nodemailer": ">=9.0.1"
    }
  }
}
